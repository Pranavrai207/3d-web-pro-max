#### TIER 2 — WebGL exists but device is low-end → Simplified 3D scene
Detect low-end devices BEFORE loading the full scene. Use a lightweight render path instead.

```js
function isLowEndDevice() {
  // SSR guard — navigator doesn't exist on the server (Next.js / Nuxt SSR will crash without this)
  if (typeof navigator === 'undefined') return false;

  // Hardware Concurrency: low-end phones usually have 4 or fewer cores
  const lowCPU = navigator.hardwareConcurrency <= 4;

  // Device Memory API (Chrome only — Safari/Firefox return undefined)
  // ?? 4 → assume 4GB when unknown, so Safari never wrongly triggers lite mode
  const lowRAM = (navigator.deviceMemory ?? 4) <= 2;

  // Small screen = almost certainly a budget phone
  const smallScreen = window.innerWidth < 480;

  return lowCPU || lowRAM || smallScreen;
}

function initThreeScene() {
  if (isLowEndDevice()) {
    initLiteScene();  // low-poly, no shadows, no postprocessing
  } else {
    initFullScene();  // full quality
  }
}

function initLiteScene() {
  renderer = new THREE.WebGLRenderer({ canvas, antialias: false }); // antialias OFF
  renderer.setPixelRatio(1);             // force 1:1 — never use devicePixelRatio on lite
  renderer.shadowMap.enabled = false;    // no shadows

  // Load a low-poly / decimated version of the model
  loader.load('/models/hero-lite.glb', (gltf) => { scene.add(gltf.scene); });

  // Respect prefers-reduced-motion — users with vestibular disorders / motion sensitivity
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // No EffectComposer — render directly
  function animate() {
    requestAnimationFrame(animate);
    // If reduced motion: freeze all rotation/animation, just render the static scene
    if (!reducedMotion && scene.children[0]) {
      scene.children[0].rotation.y += 0.003; // slow idle rotation only when allowed
    }
    renderer.render(scene, camera);
  }
  animate();
}

function initFullScene() {
  renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // always cap at 2
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;

  loader.load('/models/hero.glb', (gltf) => { scene.add(gltf.scene); });

  // EffectComposer with postprocessing passes
  composer = new EffectComposer(renderer);
  composer.addPass(new RenderPass(scene, camera));
  composer.addPass(bloomPass);

  function animate() {
    requestAnimationFrame(animate);
    composer.render();
  }
  animate();
}
```

Asset pairing rule — always ship both versions:
```
/models/hero.glb       ← full quality, Draco compressed, max 5MB
/models/hero-lite.glb  ← decimated to <500 triangles, max 1MB
```

