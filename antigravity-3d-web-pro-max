#### TIER 3 — Scene is running but FPS drops below threshold → Runtime degradation
Even mid-range phones can overheat after 30 seconds. Monitor FPS live and degrade gracefully.

```js
let frameCount   = 0;
let lastFPSCheck = performance.now();
let degraded     = false;
let useComposer  = true;  // declared here — applyDegradation() sets this to false

function monitorFPS() {
  frameCount++;
  const now     = performance.now();
  const elapsed = now - lastFPSCheck;

  if (elapsed >= 2000) { // check every 2 seconds
    const fps = (frameCount / elapsed) * 1000;
    frameCount   = 0;
    lastFPSCheck = now;

    if (!degraded && fps < 30) {
      degraded = true;
      applyDegradation();
    }
  }
}

function applyDegradation() {
  console.warn('[3D] FPS below 30 — applying degradation');

  // Step 1: drop pixel ratio
  renderer.setPixelRatio(1);

  // Step 2: remove postprocessing, render directly
  useComposer = false;

  // Step 3: reduce animation complexity (e.g. freeze particle systems)
  if (particles) particles.visible = false;

  // Step 4: if still bad after 5 more seconds, swap to CSS fallback
  setTimeout(() => {
    if (degraded) swapToCSSFallback();
  }, 5000);
}

function swapToCSSFallback() {
  // Destroy renderer to free GPU memory
  renderer.dispose();
  document.getElementById('canvas-container').style.display = 'none';
  document.getElementById('css-fallback').style.display    = 'block';
}

// Call inside your animation loop
function animate() {
  requestAnimationFrame(animate);
  monitorFPS(); // always runs
  if (useComposer) composer.render();
  else renderer.render(scene, camera);
}
```

---

#### SUMMARY — When each tier fires

| Tier | Trigger | Response |
|---|---|---|
| **Tier 1** | WebGL not supported | Skip THREE.js entirely, show CSS static scene |
| **Tier 2** | Low-end device detected at load | Simplified 3D (lite model, no shadows, no AA, pixelRatio=1) |
| **Tier 3** | FPS drops below 30 at runtime | Progressive degradation → CSS fallback as last resort |

No fallback implementation = blank screen or frozen GPU on budget phones.

